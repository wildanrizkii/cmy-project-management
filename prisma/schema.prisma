generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────── ENUMS ───────────────

enum UserRole {
  ATASAN
  BAWAHAN
}

enum Department {
  PROJECT_LEADER
  ENGINEER_PRODUCT
  ENGINEERING_NEW_PART
  CCO
  PROCUREMENT
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum ProjectStatus {
  BELUM_MULAI
  DALAM_PROSES
  SELESAI
  TERLAMBAT
  TUNDA
}

enum FaseType {
  RFQ
  DIE_GO
  EVENT_PROJECT
  MASS_PRO
}

enum HinanhyoDRType {
  HINANHYO
  DR
  KOMARIGOTO
  VA_VE
}

enum HinanhyoDRStatus {
  DITERIMA
  DITOLAK
  PENDING
}

// ─────────────── MODELS ───────────────

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  role       UserRole    @default(BAWAHAN)
  department Department?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  projectsAsLeader Project[]   @relation("ProjectLeader")
  subFasesAsPIC    SubFase[]   @relation("SubFasePIC")
  activityLogs     ActivityLog[]
  accounts         Account[]
  sessions         Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id              String        @id @default(cuid())
  model           String
  assNumber       String        @unique
  assName         String        @unique
  customer        String
  description     String?       @db.Text
  projectLeaderId String
  kebutuhanMp     Int
  aktualMp        Int?
  startDate       DateTime
  targetDate      DateTime
  priority        Priority      @default(MEDIUM)
  status          ProjectStatus @default(BELUM_MULAI)
  currentFase     FaseType      @default(RFQ)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  projectLeader User          @relation("ProjectLeader", fields: [projectLeaderId], references: [id])
  fases         ProjectFase[]
  hinanhyoDRs   HinanhyoDR[]
  activityLogs  ActivityLog[]

  @@map("projects")
}

model ProjectFase {
  id         String    @id @default(cuid())
  projectId  String
  fase       FaseType
  startDate  DateTime?
  targetDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subFases SubFase[]

  @@unique([projectId, fase])
  @@map("project_fases")
}

model SubFase {
  id                 String    @id @default(cuid())
  projectFaseId      String
  projectId          String
  name               String
  description        String?   @db.Text
  picId              String
  customerStartDate  DateTime?
  customerTargetDate DateTime?
  picStartDate       DateTime?
  picTargetDate      DateTime?
  documentUrl        String?
  isDone             Boolean   @default(false)
  gcalEventId        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  projectFase ProjectFase  @relation(fields: [projectFaseId], references: [id], onDelete: Cascade)
  pic         User         @relation("SubFasePIC", fields: [picId], references: [id])
  hinanhyoDRs HinanhyoDR[]

  @@map("sub_fases")
}

model HinanhyoDR {
  id          String           @id @default(cuid())
  projectId   String
  subFaseId   String?
  type        HinanhyoDRType
  title       String
  description String?          @db.Text
  status      HinanhyoDRStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subFase SubFase? @relation(fields: [subFaseId], references: [id])

  @@map("hinanhyo_dr")
}

model ActivityLog {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  action    String
  detail    String?  @db.Text
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}
