generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────── ENUMS ───────────────

enum UserRole {
  ATASAN
  BAWAHAN
}

enum Department {
  PROJECT_LEADER
  ENGINEER_PRODUCT
  ENGINEERING_NEW_PART
  CCO
  PROCUREMENT
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum ProjectStatus {
  BELUM_MULAI
  DALAM_PROSES
  SELESAI
  TERLAMBAT
  TUNDA
}

enum Fase {
  RFQ
  DIE_GO
  EVENT_PROJECT
  MASS_PRO
}

enum HinanhyoDRType {
  HINANHYO
  DR
}

enum HinanhyoDRStatus {
  DITERIMA
  DITOLAK
  PENDING
}

// ─────────────── MODELS ───────────────

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  role       UserRole    @default(BAWAHAN)
  department Department?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  projectsAsPIC Project[]    @relation("ProjectPIC")
  hinanhyoDRs   HinanhyoDR[]
  activityLogs  ActivityLog[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id                   String        @id @default(cuid())
  code                 String        @unique // PRJ-001, PRJ-002
  name                 String        @unique
  description          String?       @db.Text
  customer             String
  picId                String
  priority             Priority      @default(MEDIUM)
  status               ProjectStatus @default(BELUM_MULAI)
  currentFase          Fase          @default(RFQ)
  startDate            DateTime
  endDate              DateTime
  kebutuhanMp          Int
  aktualMp             Int?
  cycleTimeTarget      Int // in working days
  cycleTimeAktual      Int? // auto-calculated or manual
  rfqProgress          Int           @default(0)
  dieGoProgress        Int           @default(0)
  eventProjectProgress Int           @default(0)
  massProProgress      Int           @default(0)
  overallProgress      Float         @default(0) // (rfq+dieGo+eventProject+massPro) / 4
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  pic          User         @relation("ProjectPIC", fields: [picId], references: [id])
  hinanhyoDRs  HinanhyoDR[]
  activityLogs ActivityLog[]

  @@map("projects")
}

model HinanhyoDR {
  id          String           @id @default(cuid())
  projectId   String
  type        HinanhyoDRType
  title       String
  description String?          @db.Text
  status      HinanhyoDRStatus @default(PENDING)
  picId       String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pic     User    @relation(fields: [picId], references: [id])

  @@map("hinanhyo_dr")
}

model ActivityLog {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  action    String
  detail    String?  @db.Text
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}
